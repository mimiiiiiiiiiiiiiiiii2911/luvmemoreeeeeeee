<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Happy 3-Month Anniversary</title>

<style>

body{
margin:0;
font-family: "Segoe UI",sans-serif;
background: linear-gradient(135deg,#ffd6e8,#ffeaf3);
text-align:center;
color:#ff3d7f;
overflow:hidden;
}

h1{
margin-top:60px;
font-size:45px;
}

.subtitle{
font-size:22px;
margin-top:5px;
}

.info{
font-size:18px;
margin-top:10px;
}

#timer{
font-size:22px;
margin-top:20px;
}

#distance{
font-size:20px;
margin-top:10px;
}

button{
margin-top:30px;
background:#ff4d88;
border:none;
padding:18px 35px;
font-size:22px;
border-radius:50px;
color:white;
cursor:pointer;
box-shadow:0 10px 20px rgba(0,0,0,0.2);
transition:0.3s;
}

button:hover{
transform:scale(1.1);
}

canvas{
position:fixed;
top:0;
left:0;
pointer-events:none;
}

.footer{
position:absolute;
bottom:40px;
width:100%;
font-size:20px;
}

.music{
position:fixed;
bottom:10px;
right:10px;
opacity:0.6;
}

</style>
</head>

<body>

<h1>💗 Happy 3-Month Anniversary 💗</h1>

<div class="subtitle">Mimi loves Ragas</div>

<div class="info">✨ Together since January 2, 2026 ✨</div>

<div id="timer"></div>

<div id="distance"></div>

<button onclick="createHearts()">💖 Click My Heart</button>

<div class="footer">
9,600 km apart — but still one heart 💗
</div>

<canvas id="canvas"></canvas>

<div class="music">
<iframe width="0" height="0"
src="https://www.youtube.com/embed/2nCj8cfgSLE?autoplay=1&loop=1&playlist=2nCj8cfgSLE">
</iframe>
</div>

<script>

// LOVE TIMER
const startDate = new Date("2026-01-02T00:00:00");

function updateTimer(){

let now = new Date();
let diff = now - startDate;

let days = Math.floor(diff/(1000*60*60*24));
let hours = Math.floor((diff/(1000*60*60))%24);
let minutes = Math.floor((diff/(1000*60))%60);
let seconds = Math.floor((diff/1000)%60);

document.getElementById("timer").innerHTML =
"💗 Together for: "+days+" days "+hours+"h "+minutes+"m "+seconds+"s";

}

setInterval(updateTimer,1000);


// DISTANCE HCMC → ZURICH

function distance(lat1,lon1,lat2,lon2){

const R = 6371;

let dLat = (lat2-lat1)*Math.PI/180;
let dLon = (lon2-lon1)*Math.PI/180;

let a =
Math.sin(dLat/2)*Math.sin(dLat/2)+
Math.cos(lat1*Math.PI/180)*
Math.cos(lat2*Math.PI/180)*
Math.sin(dLon/2)*Math.sin(dLon/2);

let c = 2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));

return R*c;

}

const hcm={lat:10.8231,lon:106.6297};
const zurich={lat:47.3769,lon:8.5417};

let dist=distance(hcm.lat,hcm.lon,zurich.lat,zurich.lon);

document.getElementById("distance").innerHTML=
"🌍 Distance Ho Chi Minh City → Zurich: "+Math.round(dist)+" km";


// HEART ANIMATION

const canvas=document.getElementById("canvas");
const ctx=canvas.getContext("2d");

canvas.width=window.innerWidth;
canvas.height=window.innerHeight;

let hearts=[];

function createHearts(){

for(let i=0;i<30;i++){

hearts.push({
x:window.innerWidth/2,
y:window.innerHeight/2,
size:Math.random()*20+10,
vx:(Math.random()-0.5)*6,
vy:(Math.random()-0.5)*6,
life:100
})

}

}

function drawHeart(x,y,size){

ctx.fillStyle="#ff4d88";

ctx.beginPath();
ctx.moveTo(x,y);

ctx.bezierCurveTo(
x-size/2,y-size/2,
x-size,y+size/3,
x,y+size
);

ctx.bezierCurveTo(
x+size,y+size/3,
x+size/2,y-size/2,
x,y
);

ctx.fill();

}

function animate(){

ctx.clearRect(0,0,canvas.width,canvas.height);

hearts.forEach((h,i)=>{

h.x+=h.vx;
h.y+=h.vy;
h.life--;

drawHeart(h.x,h.y,h.size);

if(h.life<=0){
hearts.splice(i,1);
}

});

requestAnimationFrame(animate);

}

animate();

</script>

</body>
</html>
